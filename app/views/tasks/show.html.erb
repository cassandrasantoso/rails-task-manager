<h2><%= @task.id %></h2>
<p><%= @task.title %></p>
<p><%= @task.details %></p>
<p><%= @task.completed %></p>

<%= link_to "Edit", edit_task_path(@task) %>

<%= link_to "Delete",
  task_path(@task),
  data: {turbo_method: :delete, turbo_confirm: "Are You Sure?"}
%>
<%= link_to "Back to Tasks", tasks_path %>
